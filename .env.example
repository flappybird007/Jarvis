# Jarvis Konfiguration
# Kopiere diese Datei zu .env und fülle deine API-Keys ein

# OpenWeatherMap API (kostenlos: https://openweathermap.org/api)
WEATHER_API_KEY=your_weather_api_key_here

# ChatGPT API (optional: https://platform.openai.com)
CHATGPT_API_KEY=your_chatgpt_api_key_here

# Deine Stadt für Wetter
CITY=Berlin